{
  "schema_version": "phase42_staging_acceptance_decision.v1",
  "repo": "ImeshEkanayake/SL-Legal",
  "target_release_tag": "v2-phase-41-hosted-capture-execution-evidence",
  "phase_name": "V2 Phase 42: Staging Acceptance Decision",
  "execution_environment": "staging",
  "description": "Decision gate that converts hosted staging evidence, owner acceptance, operator acceptance, and residual risk evidence into a production-planning decision without authorizing production execution.",
  "forbidden_terms": [
    "X-SL-Legal-Auth-Signature",
    "X-SL-Legal-Body-SHA256",
    "sl_legal_session=",
    "Authorization: Bearer",
    "postgres://",
    "postgresql://",
    "BEGIN PRIVATE KEY",
    "BEGIN OPENSSH PRIVATE KEY",
    "raw document body",
    "raw response body",
    "This is final legal advice",
    "final legal advice"
  ],
  "prerequisites": [
    {
      "id": "phase41_manifest",
      "title": "Phase 41 hosted capture execution evidence manifest",
      "type": "file",
      "path": "rag/evals/phase41_hosted_capture_execution_evidence.json",
      "required": true
    },
    {
      "id": "phase41_contract",
      "title": "Phase 41 hosted capture execution evidence contract",
      "type": "document",
      "path": "Docs/v2_phase_41_hosted_capture_execution_evidence_contract.md",
      "required": true
    },
    {
      "id": "phase41_runbook",
      "title": "Phase 41 hosted capture execution evidence runbook",
      "type": "document",
      "path": "Docs/v2_phase_41_hosted_capture_execution_evidence_runbook.md",
      "required": true
    },
    {
      "id": "phase41_release_note",
      "title": "Phase 41 release note",
      "type": "document",
      "path": "Docs/releases/v2_phase_41_hosted_capture_execution_evidence.md",
      "required": true
    },
    {
      "id": "phase41_builder",
      "title": "Phase 41 execution evidence builder",
