{
  "schema_version": "phase6_load_scenarios.v1",
  "description": "Production API load scenarios for V2 release gates. Values use bounded local-stack targets from the V2 roadmap.",
  "scenarios": [
    {
      "name": "workspace_snapshot",
      "method": "GET",
      "path": "/v1/ui/cases/{case_id}/workspace",
      "concurrency": 20,
      "requests": 40,
      "max_p95_ms": 750,
      "max_error_rate": 0
    },
    {
      "name": "research_pack_creation",
      "method": "POST",
      "path": "/v1/research/query",
      "concurrency": 10,
      "requests": 20,
      "max_p95_ms": 8000,
      "max_error_rate": 0,
      "body": {
        "query": "industrial disputes trade union bargaining",
        "query_class": "strategy",
        "case_id": "{case_id}",
        "max_pack_items": 8,
        "max_pack_tokens": 12000
      }
    },
    {
      "name": "strategy_validation",
      "method": "POST",
      "path": "/v1/strategy/validate",
      "concurrency": 5,
      "requests": 10,
      "max_p95_ms": 1000,
      "max_error_rate": 0,
      "body": {
        "pack_id": "{pack_id}",
        "answer": "The pack-bounded draft requires lawyer verification. [{pack_item_id}]",
        "claims": [
          {
            "claim": "The pack-bounded draft requires lawyer verification.",
            "pack_item_ids": ["{pack_item_id}"],
            "confidence": "needs_lawyer_review"
          }
        ]
      }
    },
    {
      "name": "source_viewer",
      "method": "GET",
      "path": "/v1/research/packs/{pack_id}/items/{pack_item_id}/source",
      "concurrency": 10,
      "requests": 50,
      "max_p95_ms": 1500,
      "max_error_rate": 0
    },
    {
      "name": "review_queue",
      "method": "GET",
      "path": "/v1/cases/{case_id}/review/items",
      "concurrency": 10,
      "requests": 30,
      "max_p95_ms": 750,
      "max_error_rate": 0
    }
  ]
}
