  "dashboard_checks": [
    {
      "id": "api_health_dashboard_check",
      "title": "API health dashboard check",
      "metric_name": "api_health.p95_ms",
      "target": "p95 below 1500 ms for health and signed smoke paths",
      "owner": "operator",
      "severity": "critical",
      "evidence_id": "api_health_monitoring"
    },
    {
      "id": "retrieval_latency_dashboard_check",
      "title": "Retrieval latency dashboard check",
      "metric_name": "retrieval.p95_ms",
      "target": "research pack API p95 below 8000 ms for warm indexes",
      "owner": "operator",
      "severity": "high",
      "evidence_id": "retrieval_latency_monitoring"
    },
    {
      "id": "source_viewer_latency_dashboard_check",
      "title": "Source viewer latency dashboard check",
      "metric_name": "source_viewer.p95_ms",
      "target": "source viewer p95 below 1500 ms when pages and anchors exist",
      "owner": "operator",
      "severity": "high",
      "evidence_id": "source_viewer_latency_monitoring"
    },
    {
      "id": "citation_validation_dashboard_check",
      "title": "Citation validation dashboard check",
      "metric_name": "citation_validation.failure_rate",
      "target": "citation validation failures visible and reviewed with zero known uncited legal claims",
      "owner": "lawyer_owner",
      "severity": "critical",
      "evidence_id": "citation_validation_monitoring"
    },
    {
      "id": "review_queue_latency_dashboard_check",
      "title": "Review queue latency dashboard check",
      "metric_name": "review_queue.p95_ms",
      "target": "review queue p95 below 750 ms",
      "owner": "operator",
      "severity": "medium",
      "evidence_id": "review_queue_latency_monitoring"
    },
    {
      "id": "error_rate_dashboard_check",
      "title": "Application error-rate dashboard check",
      "metric_name": "application.error_rate",
      "target": "critical alerts closed and application error rate within reviewed target",
      "owner": "operator",
      "severity": "critical",
      "evidence_id": "error_rate_monitoring"
    }
  ],
  "incident_response_templates": [
    {
      "id": "api_health_incident_template",
      "title": "API health degradation incident template",
      "owner": "operator",
      "severity": "critical",
      "trigger": "API health, signed smoke, or workspace access fails during the post-cutover observation window.",
      "rollback_decision": "Use the Phase 45 deployment alias rollback point when health cannot be restored inside the observation window.",
      "evidence_path": "logs/production-cutover/phase46-api-health-incident.json"
    },
    {
      "id": "retrieval_quality_incident_template",
      "title": "Retrieval or citation quality incident template",
      "owner": "lawyer_owner",
