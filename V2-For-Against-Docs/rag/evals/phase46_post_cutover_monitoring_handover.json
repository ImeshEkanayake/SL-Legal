{
  "schema_version": "phase46_post_cutover_monitoring_handover.v1",
  "repo": "ImeshEkanayake/SL-Legal",
  "target_release_tag": "v2-phase-45-production-cutover-execution-plan",
  "phase_name": "V2 Phase 46: Post-Cutover Monitoring and Operational Handover",
  "cutover_environment": "production",
  "description": "Post-cutover monitoring and handover gate for validating production observation evidence, rollback and incident evidence, data-update separation, and operational handover.",
  "forbidden_terms": [
    "X-SL-Legal-Auth-Signature",
    "X-SL-Legal-Body-SHA256",
    "sl_legal_session=",
    "Authorization: Bearer",
    "postgres://",
    "postgresql://",
    "BEGIN PRIVATE KEY",
    "BEGIN OPENSSH PRIVATE KEY",
    "raw document body",
    "raw response body",
    "This is final legal advice",
    "final legal advice"
  ],
  "prerequisites": [
    {
      "id": "phase45_manifest",
      "title": "Phase 45 production cutover execution-plan manifest",
