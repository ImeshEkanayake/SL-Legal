      "path": "logs/production-cutover/phase46-signed-smoke-record.json",
      "accepted_statuses": [
        "signed_smoke_passed"
      ],
      "pending_statuses": [
        "awaiting_execution"
      ],
      "required_fields": {
        "signed_health_passed": true,
        "workspace_smoke_passed": true,
        "source_viewer_smoke_passed": true,
        "review_queue_smoke_passed": true,
