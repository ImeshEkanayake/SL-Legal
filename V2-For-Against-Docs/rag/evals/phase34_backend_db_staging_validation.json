{
  "schema_version": "phase34_backend_db_staging_validation.v1",
  "repo": "ImeshEkanayake/SL-Legal",
  "target_release_tag": "v2-phase-33-hosted-staging-validation",
  "phase_name": "V2 Phase 34: Real Backend and DB Staging Validation",
  "execution_environment": "staging",
  "database_mode": "read_only_validation",
  "description": "Validation gate for hosted staging evidence that proves V2 is using the real backend and a read-only staging DB path without database migration, raw data upload, or unintended writes.",
  "prerequisites": [
    {
      "id": "phase33_manifest",
      "title": "Phase 33 hosted staging validation manifest",
      "type": "file",
      "path": "rag/evals/phase33_hosted_staging_validation.json",
      "required": true
    },
    {
      "id": "phase33_contract",
      "title": "Phase 33 hosted staging validation contract",
      "type": "document",
      "path": "Docs/v2_phase_33_hosted_staging_validation_contract.md",
      "required": true
    },
    {
      "id": "phase33_runbook",
      "title": "Phase 33 hosted staging validation runbook",
      "type": "document",
      "path": "Docs/v2_phase_33_hosted_staging_validation_runbook.md",
      "required": true
    },
    {
      "id": "phase33_release_note",
      "title": "Phase 33 release note",
      "type": "document",
      "path": "Docs/releases/v2_phase_33_hosted_staging_validation.md",
      "required": true
    },
    {
      "id": "phase34_contract",
      "title": "Phase 34 backend DB staging validation contract",
      "type": "document",
      "path": "Docs/v2_phase_34_backend_db_staging_validation_contract.md",
      "required": true
    },
    {
      "id": "detached_runner_phase34_mode",
      "title": "Detached quality gate includes backend DB staging validation mode",
      "type": "file",
      "path": "scripts/run_detached_quality_gate.sh",
      "required": true
    }
  ],
  "staging_evidence": [
    {
      "id": "phase33_hosted_validation_report",
      "title": "Phase 33 hosted staging validation report",
      "type": "json_status",
      "path": "logs/readiness/phase33-hosted-staging-validation.json",
      "accepted_statuses": [
        "hosted_staging_validated"
      ],
      "pending_statuses": [
        "awaiting_hosted_execution"
      ],
      "required": true
    },
    {
      "id": "api_health_real_backend",
      "title": "Hosted API health against real backend",
      "type": "json_status",
      "path": "logs/hosted-staging/phase34-api-health.json",
      "accepted_statuses": [
        "healthy"
      ],
      "required_fields": {
        "runtime": "hosted_staging",
        "backend": "real",
        "database_connected": true
      },
      "required": true
    },
    {
      "id": "signed_workspace_api_smoke",
      "title": "Signed workspace API smoke detached log",
      "type": "detached_log",
      "path": "logs/test-runs/phase34-platform-signed-workspace-smoke.log",
      "required": true
    },
    {
      "id": "db_readonly_health",
      "title": "Read-only staging DB health",
      "type": "json_status",
      "path": "logs/hosted-staging/phase34-db-readonly-health.json",
      "accepted_statuses": [
        "healthy"
      ],
      "required_fields": {
        "access_mode": "read_only",
        "migration_applied": false
      },
      "required": true
    },
    {
      "id": "db_write_guard",
      "title": "DB write guard and audit evidence",
      "type": "json_status",
      "path": "logs/hosted-staging/phase34-db-write-guard.json",
      "accepted_statuses": [
        "no_unintended_writes"
      ],
      "required_fields": {
        "write_count": 0,
        "migration_count": 0,
        "raw_data_uploaded": false
      },
      "required": true
    },
    {
      "id": "authority_workflow_real_backend",
      "title": "Authority workflow against real backend detached log",
      "type": "detached_log",
      "path": "logs/test-runs/phase34-platform-authority-workflow.log",
      "required": true
    },
    {
      "id": "document_source_real_backend",
      "title": "Document source viewer against real backend detached log",
      "type": "detached_log",
      "path": "logs/test-runs/phase34-platform-document-source-smoke.log",
      "required": true
    },
    {
      "id": "operator_db_acceptance",
      "title": "Operator DB staging acceptance",
      "type": "json_status",
      "path": "logs/hosted-staging/phase34-operator-db-acceptance.json",
      "accepted_statuses": [
        "accepted"
      ],
      "required_fields": {
        "database_migrated": false,
        "raw_data_uploaded": false,
        "writes_reviewed": true
      },
      "required": true
    }
  ]
}
