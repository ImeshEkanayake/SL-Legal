# Local Postgres/OpenSearch/Qdrant/Redis defaults.
SL_LEGAL_POSTGRES_DB=sl_legal_assist
SL_LEGAL_POSTGRES_USER=sl_legal
SL_LEGAL_POSTGRES_PASSWORD=change-this-local-dev-password
SL_LEGAL_POSTGRES_DSN=postgresql+psycopg://sl_legal:change-this-local-dev-password@localhost:5433/sl_legal_assist
SL_LEGAL_OPENSEARCH_URL=http://localhost:9200
SL_LEGAL_OPENSEARCH_INITIAL_ADMIN_PASSWORD=change-this-local-dev-password
SL_LEGAL_OPENSEARCH_INDEX=sl_legal_retrieval_chunks
SL_LEGAL_QDRANT_URL=http://localhost:6333
SL_LEGAL_QDRANT_COLLECTION=sl_legal_retrieval_chunks
SL_LEGAL_REDIS_URL=redis://localhost:6380/0
SL_LEGAL_OBJECT_STORAGE_PROVIDER=minio
SL_LEGAL_OBJECT_STORAGE_ENDPOINT_URL=http://localhost:9000
SL_LEGAL_OBJECT_STORAGE_BUCKET=sl-legal-corpus
SL_LEGAL_OBJECT_STORAGE_REGION=us-east-1
SL_LEGAL_OBJECT_STORAGE_ACCESS_KEY=
SL_LEGAL_OBJECT_STORAGE_SECRET_KEY=
SL_LEGAL_MINIO_ROOT_USER=sl_legal_minio
SL_LEGAL_MINIO_ROOT_PASSWORD=
SL_LEGAL_EMBEDDING_PROVIDER=sentence-transformers
SL_LEGAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
SL_LEGAL_EMBEDDING_DIMENSIONS=384
SL_LEGAL_RETRIEVAL_CANDIDATE_SIZE=20
SL_LEGAL_RESEARCH_PACK_RATE_LIMIT=60
SL_LEGAL_RESEARCH_PACK_EXPAND_RATE_LIMIT=60
SL_LEGAL_STRATEGY_PROMPT_RATE_LIMIT=120
SL_LEGAL_CASE_STRUCTURE_RATE_LIMIT=30
SL_LEGAL_STRATEGY_DRAFT_RATE_LIMIT=30
SL_LEGAL_STRATEGY_VALIDATE_RATE_LIMIT=120

# Lawyer workspace UI. Use real secret values only in the deployment environment.
SL_LEGAL_API_BASE_URL=http://127.0.0.1:8000
SL_LEGAL_AUTH_HMAC_SECRET=change-this-local-dev-hmac-secret-32chars
SL_LEGAL_UI_SESSION_SECRET=change-this-local-dev-session-secret
SL_LEGAL_UI_SESSION_COOKIE_NAME=sl_legal_session
SL_LEGAL_UI_USER_ID=local-dev-user

# Azure OpenAI chat completions.
AZURE_OPENAI_ACCOUNT_NAME=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_CHAT_COMPLETIONS_URL=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
